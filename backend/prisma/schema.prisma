// This is your Prisma schema file
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  BOARD
  MANAGER
  TENANT
}

enum ShopStatus {
  VACANT
  OCCUPIED
  MAINTENANCE
}

enum InvoiceStatus {
  UNPAID
  PENDING_VERIFICATION
  PAID
  REJECTED
  ROLLED_OVER
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole
  mfaSecret    String?  @map("mfa_secret")
  mfaEnabled   Boolean  @default(false) @map("mfa_enabled")
  fullName     String?  @map("full_name")
  profileImageUrl String? @map("profile_image_url")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  tenant          Tenant?
  reviewedPayments Payment[] @relation("ReviewedPayments")
  expenses        Expense[]
  notifications   Notification[]

  @@map("users")
}

model Shop {
  id           String     @id @default(uuid())
  shopNumber   String     @unique @map("shop_number")
  floor        Int
  rentAmount   Decimal    @map("rent_amount") @db.Decimal(10, 2)
  status       ShopStatus @default(VACANT)
  createdAt    DateTime   @default(now()) @map("created_at")

  tenant          Tenant?
  utilityReadings UtilityReading[]
  invoices        Invoice[]

  @@map("shops")
}

model Tenant {
  id         String   @id @default(uuid())
  userId     String   @unique @map("user_id")
  shopId     String   @unique @map("shop_id")
  fullName   String   @map("full_name")
  phone      String
  email      String
  leaseStart DateTime @map("lease_start") @db.Date
  leaseEnd   DateTime? @map("lease_end") @db.Date
  isActive   Boolean   @default(true) @map("is_active")
  agreementUrl String?   @map("agreement_url")
  agreementPublicId String? @map("agreement_public_id")
  createdAt  DateTime  @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id])
  shop     Shop     @relation(fields: [shopId], references: [id])
  invoices Invoice[]
  payments Payment[]

  @@map("tenants")
}

model UtilityReading {
  id            String   @id @default(uuid())
  shopId        String   @map("shop_id")
  recordedById  String   @map("recorded_by")
  billingMonth  Int      @map("billing_month")
  billingYear   Int      @map("billing_year")
  electricPrev  Decimal  @map("electric_prev") @db.Decimal(10, 2)
  electricCurr  Decimal  @map("electric_curr") @db.Decimal(10, 2)
  electricRate  Decimal  @map("electric_rate") @db.Decimal(10, 2)
  waterPrev     Decimal  @map("water_prev") @db.Decimal(10, 2)
  waterCurr     Decimal  @map("water_curr") @db.Decimal(10, 2)
  waterRate     Decimal  @map("water_rate") @db.Decimal(10, 2)
  createdAt     DateTime @default(now()) @map("created_at")

  shop    Shop    @relation(fields: [shopId], references: [id])
  invoice Invoice?

  @@unique([shopId, billingMonth, billingYear])
  @@map("utility_readings")
}

model Invoice {
  id               String        @id @default(uuid())
  tenantId         String        @map("tenant_id")
  shopId           String        @map("shop_id")
  utilityReadingId String?       @unique @map("utility_reading_id")
  billingMonth     Int           @map("billing_month")
  billingYear      Int           @map("billing_year")
  rentAmount       Decimal       @map("rent_amount") @db.Decimal(10, 2)
  electricCharge   Decimal       @map("electric_charge") @db.Decimal(10, 2)
  waterCharge      Decimal       @map("water_charge") @db.Decimal(10, 2)
  serviceCharge    Decimal       @default(20.00) @map("service_charge") @db.Decimal(10, 2)
  lateFee          Decimal       @default(0.00) @map("late_fee") @db.Decimal(10, 2)
  previousBalance  Decimal       @default(0.00) @map("previous_balance") @db.Decimal(10, 2)
  totalAmount      Decimal       @map("total_amount") @db.Decimal(10, 2)
  status           InvoiceStatus @default(UNPAID)
  dueDate          DateTime      @map("due_date") @db.Date
  createdAt        DateTime      @default(now()) @map("created_at")

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  shop           Shop            @relation(fields: [shopId], references: [id])
  utilityReading UtilityReading? @relation(fields: [utilityReadingId], references: [id])
  payments       Payment[]

  @@unique([tenantId, billingMonth, billingYear])
  @@map("invoices")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  title     String
  message   String
  isRead    Boolean  @default(false) @map("is_read")
  type      String   // e.g. PAYMENT_DUE, LATE_FEE, INFO
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model Payment {
  id              String        @id @default(uuid())
  invoiceId       String        @map("invoice_id")
  tenantId        String        @map("tenant_id")
  ftNumber        String        @unique @map("ft_number")
  slipImageUrl    String?       @map("slip_image_url")
  slipPublicId    String?       @map("slip_public_id")
  status          PaymentStatus @default(PENDING)
  rejectionReason String?       @map("rejection_reason")
  reviewedById    String?       @map("reviewed_by")
  reviewedAt      DateTime?     @map("reviewed_at")
  submittedAt     DateTime      @default(now()) @map("submitted_at")

  invoice    Invoice @relation(fields: [invoiceId], references: [id])
  tenant     Tenant  @relation(fields: [tenantId], references: [id])
  reviewedBy User?   @relation("ReviewedPayments", fields: [reviewedById], references: [id])

  @@map("payments")
}

model MockBankLedger {
  id              String   @id @default(uuid())
  ftNumber        String   @unique @map("ft_number")
  amount          Decimal  @db.Decimal(10, 2)
  description     String
  transactionDate DateTime @map("transaction_date") @db.Date
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("mock_bank_ledger")
}
model Expense {
  id          String   @id @default(uuid())
  description String
  amount      Decimal  @db.Decimal(10, 2)
  category    String   // e.g. Maintenance, Salary, Utilities
  date        DateTime @db.Date
  recordedBy  String   @map("recorded_by")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [recordedBy], references: [id])

  @@map("expenses")
}

model Resource {
  id             String    @id @default(uuid())
  name           String
  quantity       Int
  category       String    // e.g. Furniture, Equipment, Tool
  condition      String    // e.g. Good, Needs Repair
  location       String    // e.g. Lobby, Floor 1
  purchaseDate   DateTime? @map("purchase_date") @db.Date
  lastMaintained DateTime? @map("last_maintained") @db.Date
  createdAt      DateTime  @default(now()) @map("created_at")

  @@map("resources")
}

model SystemSetting {
  id    String @id @default("global")
  key   String @unique
  value String @db.Text

  @@map("system_settings")
}
